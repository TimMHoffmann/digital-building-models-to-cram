// .devcontainer/devcontainer.json
{
    // Verwendet Docker Compose, um den Service "ros1_full_stack" zu starten
    "name": "ROS Noetic / KnowRob",
    "dockerComposeFile": [
        "../docker-compose.yml" 
    ],
    "service": "ros1_full_stack",
    
    // Stellt sicher, dass der Container gestartet ist, bevor VS Code sich verbindet
    "workspaceFolder": "/root/cram_ws", 
    
    // Befehle, die nach dem Aufbau des Containers und der Verbindung ausgeführt werden
    "postStartCommand": "bash -c \"source /opt/ros/noetic/setup.bash && source /root/cram_ws/devel/setup.bash\"",
    
    // VS Code Erweiterungen, die automatisch im Container installiert werden
    "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "dotjoshjohnson.ros",
        "twxs.cmake"
    ],

    // Setzt die Shell und Terminal-Einstellungen
    "remoteUser": "root", // Da Sie als root arbeiten
    "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
    }
}